# ============================================
# 1. IMPORTS & CONFIGURATION
# ============================================
import requests
import json
import time
import logging
import tempfile
import os
from pyspark.sql import SparkSession

spark = SparkSession.builder.getOrCreate()

# Paths
base_path = "abfss://sourcedata@abndemostorage.dfs.core.windows.net"
bronze_path = f"{base_path}/bronze/raw"

# Config
spark.conf.set("spark.databricks.delta.schema.autoMerge.enabled", "true")

# Logging
logging.basicConfig(level=logging.INFO)


# ============================================
# 2. AZURE STORAGE CONNECTION
# ============================================
try:
    spark.conf.set(
        "fs.azure.account.key.abndemostorage.dfs.core.windows.net",
        "<YOUR-ACCESS-KEY>"
    )
    logging.info("Azure Storage connected successfully")
except Exception as e:
    logging.error(f"Azure connection failed: {e}")
    raise


# ============================================
# 3. GENERIC API CALL WITH RETRY
# ============================================
def api_get(url, retries=3, delay=2, timeout=10):
    for attempt in range(retries):
        try:
            response = requests.get(url, timeout=timeout)
            response.raise_for_status()
            return response.json()

        except requests.exceptions.RequestException as e:
            logging.warning(f"Attempt {attempt+1} failed for {url}: {e}")

            if attempt < retries - 1:
                time.sleep(delay)
            else:
                logging.error(f"All retries failed for {url}")
                return []


# ============================================
# 4. FETCH FUNCTIONS
# ============================================
def fetch_shows():
    return api_get("https://api.tvmaze.com/shows")

def fetch_episodes(show_id):
    return api_get(f"https://api.tvmaze.com/shows/{show_id}/episodes")

def fetch_cast(show_id):
    return api_get(f"https://api.tvmaze.com/shows/{show_id}/cast")


# ============================================
# 5. DATA COLLECTION
# ============================================
try:
    shows_data = fetch_shows()
    logging.info(f"Fetched {len(shows_data)} shows")
except Exception as e:
    logging.error(f"Failed to fetch shows: {e}")
    shows_data = []

episodes_data = []
cast_data = []

for show in shows_data[:50]:
    show_id = show.get("id")

    try:
        episodes = fetch_episodes(show_id)
        cast = fetch_cast(show_id)

        if episodes:
            episodes_data.extend(episodes)

        if cast:
            cast_data.extend(cast)

    except Exception as e:
        logging.error(f"Error processing show {show_id}: {e}")


# ============================================
# 6. WRITE JSON FILES (TEMP)
# ============================================
def write_json_lines(data, name):
    try:
        path = os.path.join(tempfile.gettempdir(), f"{name}.jsonl")

        with open(path, 'w') as f:
            for item in data:
                f.write(json.dumps(item) + '\n')

        return f"file:{path}"

    except Exception as e:
        logging.error(f"File write failed for {name}: {e}")
        raise


# ============================================
# 7. SAFE SPARK FUNCTIONS
# ============================================
def safe_read_json(path):
    try:
        return spark.read.json(path)
    except Exception as e:
        logging.error(f"Spark read failed: {path} -> {e}")
        return None


def safe_write_json(df, path):
    try:
        if df is not None:
            df.write.mode("overwrite").json(path)
            logging.info(f"Written JSON to {path}")
    except Exception as e:
        logging.error(f"JSON write failed: {path} -> {e}")


def safe_write_delta(df, table_name):
    try:
        if df is not None:
            df.write.format("delta") \
                .mode("overwrite") \
                .option("mergeSchema", "true") \
                .saveAsTable(table_name)

            logging.info(f"Delta table created: {table_name}")

    except Exception as e:
        logging.error(f"Delta write failed for {table_name}: {e}")


# ============================================
# 8. EXECUTION PIPELINE
# ============================================
try:
    # Convert to Spark DataFrames
    df_shows_data = safe_read_json(write_json_lines(shows_data, "shows"))
    df_episodes_data = safe_read_json(write_json_lines(episodes_data, "episodes"))
    df_cast_data = safe_read_json(write_json_lines(cast_data, "cast"))

    # Write to ADLS
    safe_write_json(df_shows_data, f"{bronze_path}/shows")
    safe_write_json(df_episodes_data, f"{bronze_path}/episodes")
    safe_write_json(df_cast_data, f"{bronze_path}/cast")

    # Read back
    df_shows = safe_read_json(f"{bronze_path}/shows")
    df_episodes = safe_read_json(f"{bronze_path}/episodes")
    df_cast = safe_read_json(f"{bronze_path}/cast")

    # Save as Delta Tables
    safe_write_delta(df_shows, "bronze_abn.shows")
    safe_write_delta(df_episodes, "bronze_abn.episodes")
    safe_write_delta(df_cast, "bronze_abn.cast")

    logging.info("Pipeline executed successfully")

except Exception as e:
    logging.error(f"Pipeline failed: {e}")
    raise


# ============================================
# 9. SAMPLE DISPLAY (OPTIONAL)
# ============================================
try:
    display(df_shows.limit(10))
    display(df_episodes.limit(10))
    display(df_cast.limit(10))
except:
    pass
