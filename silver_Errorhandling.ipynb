# ============================================
# 1. IMPORTS & CONFIG
# ============================================
from pyspark.sql import SparkSession
from pyspark.sql.functions import explode, col, broadcast
import logging

spark = SparkSession.builder.getOrCreate()

logging.basicConfig(level=logging.INFO)

base_path = "abfss://sourcedata@abndemostorage.dfs.core.windows.net"
bronze_db = "abn_demo.bronze_abn"
silver_db = "abn_demo.silver_abn"


# ============================================
# 2. SAFE READ FUNCTION
# ============================================
def safe_read_table(table_name):
    try:
        df = spark.read.table(table_name)
        logging.info(f"Read successful: {table_name}")
        return df
    except Exception as e:
        logging.error(f"Read failed: {table_name} -> {e}")
        return None


# ============================================
# 3. SAFE WRITE FUNCTION
# ============================================
def safe_write_delta(df, table_name, partition_col=None):
    try:
        if df is None:
            logging.warning(f"Skipping write for {table_name} (DF is None)")
            return

        writer = df.write.format("delta") \
            .mode("overwrite") \
            .option("overwriteSchema", "true")

        if partition_col:
            writer = writer.partitionBy(partition_col)

        writer.saveAsTable(table_name)

        logging.info(f"Write successful: {table_name}")

    except Exception as e:
        logging.error(f"Write failed: {table_name} -> {e}")


# ============================================
# 4. SAFE OPTIMIZE
# ============================================
def safe_optimize(table_name):
    try:
        spark.sql(f"OPTIMIZE {table_name} ZORDER BY (show_id)")
        logging.info(f"Optimized: {table_name}")
    except Exception as e:
        logging.warning(f"Optimize failed: {table_name} -> {e}")


# ============================================
# 5. READ BRONZE TABLES
# ============================================
df_shows = safe_read_table(f"{bronze_db}.shows")
df_episodes = safe_read_table(f"{bronze_db}.episodes")
df_cast = safe_read_table(f"{bronze_db}.cast")


# ============================================
# 6. TRANSFORMATIONS (SILVER)
# ============================================
try:
    silver_shows = df_shows.select(
        col("id").alias("show_id"),
        col("name").alias("show_name"),
        col("language"),
        col("rating.average").alias("rating_avg"),
        explode("genres").alias("genre"),
        col("type").alias("show_type"),
        col("url"),
        col("weight"),
        col("premiered")
    ).fillna({
        "rating_avg": 0,
        "genre": "N/A",
        "url": "N/A",
        "weight": 0
    }).dropDuplicates(["show_id"])

    logging.info("silver_shows transformation complete")

except Exception as e:
    logging.error(f"Error in silver_shows: {e}")
    silver_shows = None


try:
    silver_episodes = df_episodes.select(
        col("id").alias("show_id"),
        col("name").alias("episode_name"),
        col("season"),
        col("number"),
        col("airdate"),
        col("runtime")
    ).fillna({
        "runtime": 0,
        "episode_name": "N/A"
    }).dropDuplicates(["show_id"])

    logging.info("silver_episodes transformation complete")

except Exception as e:
    logging.error(f"Error in silver_episodes: {e}")
    silver_episodes = None


try:
    silver_cast = df_cast.select(
        col("person.id").alias("show_id"),
        col("person.name").alias("cast_name"),
        col("person.country.name").alias("person_country"),
        col("character.id").alias("character_id"),
        col("character.name").alias("character_name")
    ).fillna({
        "cast_name": "N/A",
        "character_name": "N/A",
        "person_country": "N/A"
    }).dropDuplicates(["show_id"])

    logging.info("silver_cast transformation complete")

except Exception as e:
    logging.error(f"Error in silver_cast: {e}")
    silver_cast = None


# ============================================
# 7. WRITE SILVER TABLES
# ============================================
safe_write_delta(silver_shows, f"{silver_db}.shows")
safe_write_delta(silver_episodes, f"{silver_db}.episodes")
safe_write_delta(silver_cast, f"{silver_db}.cast")


# ============================================
# 8. FACT TABLE CREATION
# ============================================
try:
    if silver_shows and silver_episodes and silver_cast:

        fact_df = silver_episodes \
            .join(broadcast(silver_shows), "show_id") \
            .join(silver_cast, "show_id")

        fact_df = fact_df.select(
            "show_id",
            "show_name",
            "episode_name",
            "rating_avg",
            "language",
            "genre",
            "season",
            "airdate",
            "runtime",
            "cast_name",
            "character_name"
        )

        logging.info("Fact table transformation complete")

    else:
        fact_df = None
        logging.warning("Skipping fact table due to missing inputs")

except Exception as e:
    logging.error(f"Fact table error: {e}")
    fact_df = None


# ============================================
# 9. WRITE FACT TABLE
# ============================================
safe_write_delta(
    fact_df,
    f"{silver_db}.fact_table",
    partition_col="season"
)


# ============================================
# 10. OPTIMIZATION
# ============================================
safe_optimize(f"{silver_db}.shows")
safe_optimize(f"{silver_db}.episodes")
safe_optimize(f"{silver_db}.cast")
safe_optimize(f"{silver_db}.fact_table")


# ============================================
# 11. OPTIONAL DISPLAY
# ============================================
try:
    display(fact_df.limit(10))
except:
    pass


# ============================================
# DONE
# ============================================
logging.info("Silver layer pipeline completed successfully")
